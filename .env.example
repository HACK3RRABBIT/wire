# Telegram API credentials — get from https://my.telegram.org
API_ID=
API_HASH=
# Telethon StringSession for the account used to crawl. Generate once with:
#   python -m app.cli login
SESSION_STRING=

MEILI_URL=http://localhost:7700
MEILI_KEY=masterKey

# Comma-separated public channel/group usernames to start crawling from
SEED_CHANNELS=telegram,durov

# Comma-separated chat IDs to never index (your own channels/groups)
EXCLUDE_CHAT_IDS=

# Any OpenAI-compatible endpoint (OpenAI, a local router, etc). Used by /analyze
# to summarize search results. Leave AI_API_KEY blank to disable the feature.
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_MAX_ROUNDS=5

# All of the above AI_* settings can also be set/changed later from the web UI
# (the "AI settings" panel) without editing this file or restarting the server.
